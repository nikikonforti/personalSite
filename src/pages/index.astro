---
import Layout from '../layouts/Layout.astro';
---

<Layout title="niki konforti" description="niki konforti — software engineer, artist, baker of things">

  <!-- ── Nav ── -->
  <nav class="fixed top-0 left-0 right-0 z-50 px-6 py-5 flex items-center justify-between">
    <a href="/" class="nav-link" aria-label="home">
      <svg viewBox="0 0 36 18" width="42" height="22" aria-hidden="true">
        <path d="M2 16 L2 2 L16 16 L16 2 M16 9 L28 2 M16 9 L28 16"
              stroke="#2c2417" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
    </a>
    <div class="flex gap-6 text-sm font-body font-medium">
      <a href="/work"   class="nav-link text-bark/70 hover:text-terra transition-colors">work</a>
      <a href="/art"    class="nav-link text-bark/70 hover:text-terra transition-colors">art</a>
      <a href="/resume" class="nav-link text-bark/70 hover:text-terra transition-colors">resume</a>
      <a href="https://github.com/nikikonforti" target="_blank" rel="noopener" class="nav-link text-bark/70 hover:text-terra transition-colors">github</a>
    </div>
  </nav>

  <!-- ── Hero ── -->
  <main class="min-h-screen flex flex-col lg:flex-row items-center justify-center gap-12 lg:gap-20 px-6 pt-24 pb-12 max-w-5xl mx-auto">

    <!-- Photo -->
    <div class="stagger-1 flex-shrink-0 relative">
      <div class="absolute -inset-3 rounded-full bg-cream-dark/60 animate-float" style="animation-delay: 0.5s;"></div>
      <img
        id="niki-photo"
        src="/content/profile.jpg"
        alt="Niki Konforti"
        class="relative w-52 h-52 lg:w-64 lg:h-64 rounded-full object-cover object-top border-4 border-cream-dark shadow-lg cursor-pointer hover:scale-[1.03] transition-transform duration-300"
        title="click me 🎉"
      />
    </div>

    <!-- Text -->
    <div class="flex flex-col gap-5 max-w-lg text-center lg:text-left">
      <div class="stagger-2">
        <h1 class="font-display text-5xl lg:text-6xl font-semibold leading-tight text-bark">
          hi, i'm <em class="text-terra not-italic">niki</em>.
        </h1>
      </div>

      <p class="stagger-3 font-body text-bark/75 text-lg leading-relaxed">
        software engineer @ google nyc · columbia cs grad
      </p>

      <div class="stagger-4 flex flex-wrap gap-3 justify-center lg:justify-start mt-1">
        <a href="/work"
           class="px-5 py-2.5 bg-terra text-cream rounded-full text-sm font-medium font-body hover:bg-terra/85 transition-colors shadow-sm">
          see my work
        </a>
        <a href="/art"
           class="px-5 py-2.5 border border-bark/20 text-bark rounded-full text-sm font-medium font-body hover:border-sage hover:text-sage transition-colors">
          see my art
        </a>
        <a href="mailto:nfk2107@columbia.edu"
           class="px-5 py-2.5 border border-bark/20 text-bark rounded-full text-sm font-medium font-body hover:border-rose hover:text-rose transition-colors">
          say hello
        </a>
      </div>

      <!-- Floating tags -->
      <div class="stagger-5 flex flex-wrap gap-2 justify-center lg:justify-start mt-2">
        {['piano','painting','pottery','swimming','cooking'].map(tag => (
          <span class="px-3 py-1 bg-cream-dark text-bark/60 text-xs font-body rounded-full border border-bark/10">
            {tag}
          </span>
        ))}
      </div>
    </div>

  </main>

  <!-- ── Subtle footer ── -->
  <footer class="text-center -mt-8 pb-8 text-bark/30 font-body flex items-center justify-center gap-4">
    <a href="https://github.com/nikikonforti" class="hover:text-terra transition-colors" target="_blank" aria-label="GitHub">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
    </a>
    <a href="https://www.facebook.com/niki.konforti" class="hover:text-terra transition-colors" target="_blank" aria-label="Facebook">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
    </a>
  </footer>

</Layout>

<script>
  // Photo click → confetti burst
  document.getElementById('niki-photo')?.addEventListener('click', () => {
    (window as any).fireConfetti?.();
  });
</script>
