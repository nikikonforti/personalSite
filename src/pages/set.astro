---
import Layout from '../layouts/Layout.astro';
---

<Layout title="set game — niki konforti" description="Play Set, the card pattern recognition game">

  <nav class="fixed top-0 left-0 right-0 z-50 px-6 py-5 flex items-center justify-between">
    <a href="/" class="nav-link" aria-label="home">
      <svg viewBox="0 0 36 18" width="42" height="22" aria-hidden="true">
        <path d="M2 16 L2 2 L16 16 L16 2 M16 9 L28 2 M16 9 L28 16"
              stroke="#2c2417" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
    </a>
    <div class="flex gap-6 text-sm font-body font-medium">
      <a href="/work"   class="nav-link text-bark/70 hover:text-terra transition-colors">work</a>
      <a href="/art"    class="nav-link text-bark/70 hover:text-terra transition-colors">art</a>
      <a href="/resume" class="nav-link text-bark/70 hover:text-terra transition-colors">resume</a>
      <a href="https://github.com/nikikonforti" target="_blank" rel="noopener" class="nav-link text-bark/70 hover:text-terra transition-colors">github</a>
    </div>
  </nav>

  <main class="max-w-4xl mx-auto px-4 pt-24 pb-16">

    <!-- Header + stats -->
    <div class="flex items-start justify-between mb-5 flex-wrap gap-4">
      <div>
        <h1 class="font-display text-4xl font-semibold text-bark">set.</h1>
        <p class="text-bark/50 text-sm font-body mt-1">find three cards that form a set</p>
      </div>
      <div class="flex gap-7">
        <div class="text-right">
          <div id="score-val" class="font-display text-3xl font-semibold text-bark">0</div>
          <div class="text-xs text-bark/40 font-body uppercase tracking-widest mt-0.5">score</div>
        </div>
        <div class="text-right">
          <div id="timer-val" class="font-display text-3xl font-semibold text-bark">0:00</div>
          <div class="text-xs text-bark/40 font-body uppercase tracking-widest mt-0.5">time</div>
        </div>
        <div class="text-right">
          <div id="deck-val" class="font-display text-3xl font-semibold text-bark">72</div>
          <div class="text-xs text-bark/40 font-body uppercase tracking-widest mt-0.5">deck</div>
        </div>
      </div>
    </div>

    <!-- Rules -->
    <details class="mb-5 group">
      <summary class="text-sm font-body text-bark/45 hover:text-bark/65 cursor-pointer select-none transition-colors list-none flex items-center gap-1.5">
        <span class="group-open:rotate-90 transition-transform inline-block">▸</span> how to play
      </summary>
      <div class="mt-3 p-4 bg-cream-dark/60 rounded-xl font-body text-sm text-bark/60 leading-relaxed max-w-lg">
        A <span class="text-bark/80 font-medium">set</span> is three cards where, for each of the four features
        (number, color, shape, shading), the values are either <em>all the same</em> or <em>all different</em>.
        Click three cards to submit. <span class="text-bark/80">+3</span> for a correct set,
        <span class="text-bark/80">−1</span> for a wrong guess or an unnecessary deal.
      </div>
    </details>

    <!-- Controls -->
    <div class="flex gap-2.5 mb-4 flex-wrap">
      <button id="new-game-btn"
        class="px-4 py-2 bg-terra text-cream rounded-full text-sm font-body font-medium hover:bg-terra/85 transition-colors">
        new game
      </button>
      <button id="deal-btn"
        class="px-4 py-2 border border-bark/20 text-bark/70 rounded-full text-sm font-body hover:border-bark/40 hover:text-bark transition-colors">
        no set? deal 3 more
      </button>
      <button id="hint-btn"
        class="px-4 py-2 border border-bark/20 text-bark/70 rounded-full text-sm font-body hover:border-bark/40 hover:text-bark transition-colors">
        hint
      </button>
    </div>

    <!-- Message bar -->
    <div class="h-6 mb-3">
      <span id="msg" class="text-sm font-body text-bark/50"></span>
    </div>

    <!-- Board -->
    <div id="game-board" class="grid grid-cols-3 gap-3 mx-auto" style="max-width:516px;"></div>

  </main>

  <!-- Game over overlay -->
  <div id="gameover" class="hidden fixed inset-0 z-50 flex items-center justify-center"
       style="background:rgba(62,47,37,0.3); backdrop-filter:blur(4px);">
    <div class="bg-white rounded-2xl p-10 text-center shadow-2xl" style="min-width:290px;">
      <p class="font-display text-4xl font-semibold text-bark mb-1">done!</p>
      <p class="font-body text-bark/50 text-sm mb-6">no more sets remaining</p>
      <div class="flex gap-10 justify-center mb-7">
        <div>
          <div id="go-score" class="font-display text-3xl font-semibold text-bark"></div>
          <div class="text-xs text-bark/40 font-body uppercase tracking-widest mt-0.5">score</div>
        </div>
        <div>
          <div id="go-time" class="font-display text-3xl font-semibold text-bark"></div>
          <div class="text-xs text-bark/40 font-body uppercase tracking-widest mt-0.5">time</div>
        </div>
      </div>
      <button id="again-btn"
        class="px-6 py-2.5 bg-terra text-cream rounded-full text-sm font-body font-medium hover:bg-terra/85 transition-colors">
        play again
      </button>
    </div>
  </div>

</Layout>

<style is:global>
  #game-board {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    max-width: 540px;
    margin: 0 auto;
  }

  .set-card {
    background: #fff;
    border-radius: 12px;
    border: none;
    box-shadow: 0 0 0 2px #b8b2aa, 0 2px 8px rgba(0,0,0,0.08);
    cursor: pointer;
    padding: 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    aspect-ratio: 7/4;
    filter: brightness(1);
    transition: transform 0.15s ease, box-shadow 0.15s ease, filter 0.2s ease;
    user-select: none;
    -webkit-user-select: none;
    overflow: hidden;
  }
  .set-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.35);
    pointer-events: none;
    display: block;
  }
  .set-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 0 0 2px #8a827a, 0 8px 24px rgba(0,0,0,0.13);
  }
  .set-card.selected {
    box-shadow: 0 0 0 2px #4a7c59, 0 0 0 5px rgba(74,124,89,0.25), 0 8px 24px rgba(0,0,0,0.12);
    transform: translateY(-4px);
    filter: brightness(0.88);
  }
  .set-card.flash-ok {
    box-shadow: 0 0 0 2px #4a9e6e !important;
    background: #edf8f2 !important;
    animation: pulse-ok 0.55s ease;
  }
  .set-card.flash-no {
    box-shadow: 0 0 0 2px #c0392b !important;
    background: #fdf0f0 !important;
    animation: shake-no 0.42s ease;
  }
  .set-card.hint-glow {
    box-shadow: 0 0 0 2px #b8860b, 0 0 0 5px rgba(184,134,11,0.3);
  }

@keyframes pulse-ok  { 0%,100%{transform:scale(1)} 40%{transform:scale(1.05) translateY(-4px)} }
  @keyframes shake-no  { 0%,100%{transform:translateX(0)} 25%{transform:translateX(-8px)} 75%{transform:translateX(8px)} }
</style>

<script>
  (() => {
    // ─── Attributes ────────────────────────────────────────────
    const COLORS  = ['red','green','purple'];
    const SHAPES  = ['diamond','oval','squiggle'];
    const FILLS   = ['solid','shaded','empty'];
    const NUMS    = [1,2,3];
    const NUM_WORDS = { 1:'one', 2:'two', 3:'three' };
    const CARD_IMG_BASE = 'https://set-project.onrender.com/static/cards';

    // ─── Deck ──────────────────────────────────────────────────
    function makeDeck() {
      const d = [];
      for (const n of NUMS)
        for (const c of COLORS)
          for (const s of SHAPES)
            for (const f of FILLS)
              d.push({ n, c, s, f });
      return shuffle(d);
    }

    function shuffle(a) {
      const b = [...a];
      for (let i = b.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [b[i], b[j]] = [b[j], b[i]];
      }
      return b;
    }

    // ─── Set validation ────────────────────────────────────────
    function isSet(cards) {
      return ['n','c','s','f'].every(k => {
        const u = new Set(cards.map(c => c[k])).size;
        return u === 1 || u === 3;
      });
    }

    function findSet(hand) {
      for (let i = 0; i < hand.length - 2; i++)
        for (let j = i + 1; j < hand.length - 1; j++)
          for (let k = j + 1; k < hand.length; k++)
            if (isSet([hand[i], hand[j], hand[k]])) return [i, j, k];
      return null;
    }


    function cardImgSrc(card) {
      return `${CARD_IMG_BASE}/${NUM_WORDS[card.n]}_${card.c}_${card.s}_${card.f}.png`;
    }

    function cardHTML(card, idx) {
      return `<div class="set-card" data-idx="${idx}">
        <img src="${cardImgSrc(card)}" alt="${card.n} ${card.c} ${card.s} ${card.f}" draggable="false" />
      </div>`;
    }

    // ─── State ─────────────────────────────────────────────────
    let deck = [], hand = [], sel = [], score = 0, secs = 0, clock = null;

    const $board    = document.getElementById('game-board');
    const $score    = document.getElementById('score-val');
    const $timer    = document.getElementById('timer-val');
    const $deck     = document.getElementById('deck-val');
    const $msg      = document.getElementById('msg');
    const $gameover = document.getElementById('gameover');

    // ─── Game flow ─────────────────────────────────────────────
    function startGame() {
      deck = makeDeck(); hand = []; sel = []; score = 0; secs = 0;
      clearInterval(clock);
      $gameover.classList.add('hidden');
      updateStats();
      for (let i = 0; i < 9; i++) hand.push(deck.pop());
      render();
      clock = setInterval(() => { secs++; $timer.textContent = fmt(secs); }, 1000);
      msg('');
    }

    function render() {
      $board.innerHTML = hand.map((c, i) => cardHTML(c, i)).join('');
      $board.querySelectorAll('.set-card').forEach(el =>
        el.addEventListener('click', () => onCard(+el.dataset.idx))
      );
      updateStats();
    }

    function onCard(idx) {
      const pos = sel.indexOf(idx);
      const el  = $board.querySelector(`[data-idx="${idx}"]`);
      if (pos === -1) {
        if (sel.length === 3) return;
        sel.push(idx);
        el.classList.add('selected');
      } else {
        sel.splice(pos, 1);
        el.classList.remove('selected');
      }
      if (sel.length === 3) checkSel();
    }

    function checkSel() {
      if (isSet(sel.map(i => hand[i]))) onCorrect(); else onWrong();
    }

    function onCorrect() {
      setScore(score + 3);
      flash('flash-ok');
      msg('✓ set! +3');
      setTimeout(() => {
        replaceCards([...sel]);
        sel = [];
        if (!hand.length || (!findSet(hand) && deck.length === 0)) { endGame(); return; }
        render();
        msg('');
      }, 650);
    }

    function onWrong() {
      setScore(score - 1);
      flash('flash-no');
      msg('✗ not a set  −1');
      setTimeout(() => { sel = []; render(); msg(''); }, 700);
    }

    function flash(cls) {
      sel.forEach(i => {
        const el = $board.querySelector(`[data-idx="${i}"]`);
        el.classList.remove('selected');
        el.classList.add(cls);
      });
    }

    function replaceCards(indices) {
      if (hand.length > 9 && deck.length > 0) {
        // Board oversized — just remove matched cards (shrink back toward 9)
        [...indices].sort((a, b) => b - a).forEach(i => hand.splice(i, 1));
      } else if (deck.length > 0) {
        // Replace in-place to maintain 9
        indices.forEach(i => { hand[i] = deck.pop(); });
      } else {
        // Deck empty — just remove
        [...indices].sort((a, b) => b - a).forEach(i => hand.splice(i, 1));
      }
    }

    function dealMore() {
      if (deck.length < 3) { msg('no cards left in deck'); setTimeout(() => msg(''), 2000); return; }
      if (findSet(hand)) {
        setScore(score - 1);
        msg('there was a set on the board!  −1');
        sel = [];
        render();
        setTimeout(() => msg(''), 2200);
        return;
      }
      msg('dealing 3 more...');
      for (let i = 0; i < 3; i++) hand.push(deck.pop());
      sel = [];
      render();
      setTimeout(() => msg(''), 2200);
    }

    function hint() {
      const found = findSet(hand);
      if (!found) { msg('no sets on the board!'); setTimeout(() => msg(''), 2000); return; }
      const el = $board.querySelector(`[data-idx="${found[0]}"]`);
      el.classList.add('hint-glow');
      setTimeout(() => el.classList.remove('hint-glow'), 2200);
      msg('one card is highlighted ↑');
      setTimeout(() => msg(''), 2500);
    }

    function endGame() {
      clearInterval(clock);
      document.getElementById('go-score').textContent = score;
      document.getElementById('go-time').textContent  = fmt(secs);
      $gameover.classList.remove('hidden');
    }

    function setScore(v)  { score = v; $score.textContent = v; }
    function updateStats(){ $score.textContent = score; $timer.textContent = fmt(secs); $deck.textContent = deck.length; }
    function msg(t)       { $msg.textContent = t; }
    function fmt(s)       { return `${Math.floor(s / 60)}:${String(s % 60).padStart(2, '0')}`; }

    // ─── Wiring ────────────────────────────────────────────────
    document.getElementById('new-game-btn').addEventListener('click', startGame);
    document.getElementById('deal-btn').addEventListener('click', dealMore);
    document.getElementById('hint-btn').addEventListener('click', hint);
    document.getElementById('again-btn').addEventListener('click', startGame);

    startGame();
  })();
</script>
