---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'niki konforti',
  description = 'niki konforti — software engineer, artist, baker of things',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Nicole Konforti" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Fonts loaded in global.css via @import -->
  </head>
  <body class="min-h-screen bg-cream text-bark">

    <!-- Custom cursor (desktop only) -->
    <div id="cursor"></div>
    <canvas id="sparkle-canvas"></canvas>
    <canvas id="confetti-canvas"></canvas>

    <!-- Konami easter egg overlay -->
    <div id="konami-overlay" role="dialog" aria-modal="true">
      <div style="font-size:3rem">🎨✨🎹</div>
      <h2>you found a secret!</h2>
      <p>hi! i'm really glad you're snooping around.<br/>here's a little reward for your curiosity ☺</p>
      <button id="konami-close">close & continue exploring</button>
    </div>

    <slot />

    <script>
      // ── Custom cursor ──────────────────────────────────
      const cursor = document.getElementById('cursor');
      if (cursor && window.matchMedia('(pointer: fine)').matches) {
        document.addEventListener('mousemove', (e) => {
          cursor.style.left = e.clientX + 'px';
          cursor.style.top  = e.clientY + 'px';
        });
        document.querySelectorAll('a, button, [data-hover]').forEach(el => {
          el.addEventListener('mouseenter', () => cursor.classList.add('hovering'));
          el.addEventListener('mouseleave', () => cursor.classList.remove('hovering'));
        });
      }

      // ── Sparkle trail ─────────────────────────────────
      const sc = document.getElementById('sparkle-canvas') as HTMLCanvasElement;
      if (sc && window.matchMedia('(pointer: fine)').matches) {
        const ctx = sc.getContext('2d')!;
        sc.width = window.innerWidth;
        sc.height = window.innerHeight;
        window.addEventListener('resize', () => {
          sc.width = window.innerWidth;
          sc.height = window.innerHeight;
        });

        const sparks: { x: number; y: number; r: number; a: number; vx: number; vy: number; color: string }[] = [];
        const COLORS = ['#c9714a', '#d4a5a5', '#8a9e7e', '#e8b99e', '#f0e8dc'];

        document.addEventListener('mousemove', (e) => {
          if (Math.random() > 0.4) return;
          sparks.push({
            x: e.clientX, y: e.clientY,
            r: Math.random() * 3 + 1,
            a: 1,
            vx: (Math.random() - 0.5) * 1.5,
            vy: (Math.random() - 0.5) * 1.5 - 0.5,
            color: COLORS[Math.floor(Math.random() * COLORS.length)],
          });
        });

        function drawSparks() {
          ctx.clearRect(0, 0, sc.width, sc.height);
          for (let i = sparks.length - 1; i >= 0; i--) {
            const s = sparks[i];
            ctx.globalAlpha = s.a;
            ctx.beginPath();
            ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
            ctx.fillStyle = s.color;
            ctx.fill();
            s.x += s.vx;
            s.y += s.vy;
            s.a -= 0.03;
            if (s.a <= 0) sparks.splice(i, 1);
          }
          ctx.globalAlpha = 1;
          requestAnimationFrame(drawSparks);
        }
        drawSparks();
      }

      // ── Konami code ───────────────────────────────────
      const KONAMI = ['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a'];
      let ki = 0;
      document.addEventListener('keydown', (e) => {
        if (e.key === KONAMI[ki]) {
          ki++;
          if (ki === KONAMI.length) {
            ki = 0;
            const overlay = document.getElementById('konami-overlay')!;
            overlay.classList.add('active');
            overlay.focus();
            fireConfetti();
          }
        } else {
          ki = 0;
        }
      });
      document.getElementById('konami-close')?.addEventListener('click', () => {
        document.getElementById('konami-overlay')!.classList.remove('active');
      });

      // ── Confetti ──────────────────────────────────────
      const cc = document.getElementById('confetti-canvas') as HTMLCanvasElement;
      const cctx = cc?.getContext('2d');
      let confettiPieces: any[] = [];

      function fireConfetti() {
        if (!cc || !cctx) return;
        cc.width = window.innerWidth;
        cc.height = window.innerHeight;
        const COLS = ['#c9714a','#d4a5a5','#8a9e7e','#e8b99e','#faf7f2','#2c2417'];
        for (let i = 0; i < 120; i++) {
          confettiPieces.push({
            x: Math.random() * cc.width,
            y: -10,
            w: Math.random() * 10 + 4,
            h: Math.random() * 6 + 3,
            color: COLS[Math.floor(Math.random() * COLS.length)],
            vx: (Math.random() - 0.5) * 4,
            vy: Math.random() * 3 + 2,
            rot: Math.random() * 360,
            rotV: (Math.random() - 0.5) * 6,
            a: 1,
          });
        }
        animateConfetti();
      }

      function animateConfetti() {
        if (!cc || !cctx || confettiPieces.length === 0) return;
        cctx.clearRect(0, 0, cc.width, cc.height);
        confettiPieces = confettiPieces.filter(p => p.a > 0);
        for (const p of confettiPieces) {
          cctx.save();
          cctx.globalAlpha = p.a;
          cctx.translate(p.x + p.w / 2, p.y + p.h / 2);
          cctx.rotate((p.rot * Math.PI) / 180);
          cctx.fillStyle = p.color;
          cctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
          cctx.restore();
          p.x += p.vx;
          p.y += p.vy;
          p.rot += p.rotV;
          if (p.y > cc.height) p.a -= 0.05;
        }
        if (confettiPieces.length > 0) requestAnimationFrame(animateConfetti);
        else cctx.clearRect(0, 0, cc.width, cc.height);
      }

      // ── Export fireConfetti for photo click ───────────
      (window as any).fireConfetti = fireConfetti;
    </script>

    <style is:global>
      @import '../styles/global.css';
    </style>
  </body>
</html>
